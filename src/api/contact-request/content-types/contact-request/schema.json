{
  "kind": "collectionType",
  "collectionName": "contact_requests",
  "info": {
    "singularName": "contact-request",
    "pluralName": "contact-requests",
    "displayName": "contact-request"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "fullName": {
      "type": "string"
    },
    "phoneNumber": {
      "type": "string"
    },
    "postcode": {
      "type": "string"
    },
    "serviceRequired": {
      "type": "enumeration",
      "enum": [
        "Immediate Emergency Fitting",
        "Premium Tyre Service",
        "Puncture Repair",
        "Mobile Trailer Tyre Fitting",
        "Wheel Balancing"
      ]
    },
    "message": {
      "type": "richtext"
    },
    "bookingStatus": {
      "type": "enumeration",
      "enum": [
        "Pending",
        "Approved",
        "In Progress",
        "Completed",
        "Rejected"
      ]
    }
  }
}
